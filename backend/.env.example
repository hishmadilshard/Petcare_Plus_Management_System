# =====================================================
# PetCare Plus - Environment Variables
# Copy this to .env and fill in your values
# =====================================================

# Server
PORT=5000
NODE_ENV=development
API_VERSION=v1

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=petcare_plus
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer) - optional
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# SMS - Twilio (leave empty for mock/console mode)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
CLINIC_PHONE_NUMBER=0112345678

# Firebase Cloud Messaging (leave empty for mock mode)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3000
MOBILE_APP_URL=http://localhost:19006